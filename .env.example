# Required environment variables — add these in Vercel → Project → Settings → Environment Variables
# Copy this file to .env.local for local development with `vercel dev`

# Stripe secret key (sk_test_... for testing, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret (whsec_...) — get from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Password for the /admin page (pick something strong)
ADMIN_PASSWORD=replace_me_with_a_strong_password

# Optional: where customers go after successful subscription (defaults to the site root)
PUBLIC_SITE_URL=https://landmarkdigital.agency
